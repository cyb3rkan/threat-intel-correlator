admin@local.test# configs/example.env
# Örnek ortam değişkenleri. Gerçek değerlerle .env olarak kopyalayın.
# ASLA bu dosyayı gerçek secret'larla doldurup commit etmeyin.

# Zorunlu: uygulama çalışma dizini ve cache konumu
TIC_PATHS__WORKING_DIR=/opt/tic/work
TIC_PATHS__CACHE_DIR=/opt/tic/cache
TIC_PATHS__AUDIT_LOG_PATH=/opt/tic/audit.log

# Log seviyesi: DEBUG | INFO | WARNING | ERROR
TIC_LOG_LEVEL=INFO

# Log formatı: json | console
TIC_LOG_FORMAT=json

# HTTP ayarları (opsiyonel, default değerler config/default.yaml'da)
# TIC_HTTP__CONNECT_TIMEOUT_SECONDS=5.0
# TIC_HTTP__READ_TIMEOUT_SECONDS=15.0
# TIC_HTTP__VERIFY_TLS=true

# AI desteği (varsayılan: kapalı)
# TIC_AI__ENABLED=false
# TIC_AI__MODEL=gpt-4o
# TIC_AI__ENDPOINT_ALLOWLIST=["https://api.openai.com"]

# Provider ayarları — keyring üzerinden secret yönetimi
# TIC_PROVIDERS__VIRUSTOTAL__KEYRING_SERVICE=tic-vt
# TIC_PROVIDERS__VIRUSTOTAL__KEYRING_USER=default
# TIC_PROVIDERS__VIRUSTOTAL__ENABLED=true

# TIC_PROVIDERS__ABUSEIPDB__KEYRING_SERVICE=tic-abuseipdb
# TIC_PROVIDERS__ABUSEIPDB__KEYRING_USER=default
# TIC_PROVIDERS__ABUSEIPDB__ENABLED=true

# HMAC redaction keyring
# TIC_REDACTION_HMAC_KEYRING_SERVICE=tic-redaction-hmac
# TIC_REDACTION_HMAC_KEYRING_USER=default